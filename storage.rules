rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ── Perfiles de usuario — solo el propio usuario ──
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024 // 10 MB max
         && (request.resource.contentType.startsWith('image/')
         || request.resource.contentType == 'application/pdf');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Archivos públicos de la app (logos, assets) ──
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Solo deploy
    }
  }
}
